@model IEnumerable<proyecto.Application.DTOs.PujasDTO>

@{
    ViewData["Title"] = "Historial de Pujas";
}

<div class="container mt-5">

    <div class="glass-card p-4">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="text-light mb-0">
                <i class="bi bi-cash-coin me-2"></i>Historial de Pujas
            </h2>

            <a asp-action="Create" class="btn btn-warning">
                <i class="bi bi-plus-circle me-1"></i>Nueva Puja
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle text-light custom-table">
                <thead>
                    <tr>
                        <th>Subasta</th>
                        <th>Comprador</th>
                        <th>Monto</th>
                        <th>Fecha</th>
                        <th>Estado</th>
                        <th class="text-end">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>#@item.SubastaId</td>

                            <td>
                                <span class="fw-semibold">
                                    Usuario #@item.CompradorId
                                </span>
                            </td>

                            <td>
                                <span class="badge bg-warning text-dark fs-6">
                                    ₡ @item.MontoOfertado.ToString("N0")
                                </span>
                            </td>

                            <td>
                                @item.FechaHora.ToString("dd MMM yyyy - HH:mm")
                            </td>

                            <td>
                                @if (item.Notificado)
                                {
                                    <span class="badge bg-success">Notificado</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Pendiente</span>
                                }
                            </td>

                            <td class="text-end">
                                <a asp-action="Details" class="btn btn-sm btn-outline-light me-1">
                                    <i class="bi bi-eye"></i>
                                </a>

                                <a asp-action="Delete" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>

</div>
