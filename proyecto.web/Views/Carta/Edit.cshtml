@model proyecto.Application.DTOs.CartaDTO

@{
    ViewData["Title"] = "Editar Carta";
    var categorias = ViewBag.Categorias as IEnumerable<proyecto.Application.DTOs.CategoriaDTO>;
    var usuarioActual = ViewBag.UsuarioActual as proyecto.Application.DTOs.UsuarioDTO;
}

<div class="container my-4">
    <div class="card shadow-sm" style="max-width: 900px; margin:0 auto; border-radius:12px;">
        <div class="card-header bg-warning text-dark fw-bold">
            <i class="bi bi-pencil-square me-2"></i> Editar carta
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="CartaId" />

                <!-- Nombre -->
                <div class="mb-3">
                    <label asp-for="NombreCarta" class="form-label"></label>
                    <input asp-for="NombreCarta" class="form-control" />
                    <span asp-validation-for="NombreCarta" class="text-danger"></span>
                </div>

                <!-- Descripción -->
                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <!-- Condición -->
                <div class="mb-3">
                    <label asp-for="Condicion" class="form-label"></label>
                    <input asp-for="Condicion" class="form-control" />
                    <span asp-validation-for="Condicion" class="text-danger"></span>
                </div>


                <!-- Edición (obligatoria) -->
                <div class="mb-3">
                    <label asp-for="Edicion" class="form-label"></label>
                    <input asp-for="Edicion" class="form-control" />
                    <span asp-validation-for="Edicion" class="text-danger"></span>
                </div>

                <!-- Rareza (obligatoria) -->
                <div class="mb-3">
                    <label asp-for="Rareza" class="form-label"></label>
                    <input asp-for="Rareza" class="form-control" />
                    <span asp-validation-for="Rareza" class="text-danger"></span>
                </div>

                <!-- Categorías -->
                <div class="mb-3">
                    <label class="form-label">Categorías</label>
                    <select name="categoriasSeleccionadas" class="form-select" multiple>
                        @if (categorias != null)
                        {
                            foreach (var categoria in categorias)
                            {
                                var selected = Model.CartaCategoria?.Any(cc => cc.CategoriaId == categoria.CategoriaId) ?? false;
                                <option value="@categoria.CategoriaId" selected="@(selected ? "selected" : null)">
                                    @categoria.NombreCategoria
                                </option>
                            }
                        }
                    </select>
                    <small class="text-muted">Debe seleccionar al menos una categoría</small>
                </div>

                <!-- Imágenes actuales -->
                <div class="mb-3">
                    <label class="form-label">Imágenes actuales</label>
                    <div class="d-flex flex-wrap gap-3">
                        @if (Model.ImagenesCartaNavigation != null && Model.ImagenesCartaNavigation.Any())
                        {
                            int index = 0;
                            foreach (var img in Model.ImagenesCartaNavigation)
                            {
                                <div class="d-flex flex-column align-items-center me-2">
                                    <img src="@img.UrlImagen" alt="Imagen carta" style="max-height:100px; max-width:100px; object-fit:contain;" />
                                    <input type="radio" name="ImagenPrincipalIndex" value="@index" @(img.EsPrincipal ? "checked" : "") />
                                    <label>Principal</label>
                                </div>
                                index++;
                            }
                        }
                        else
                        {
                            <span class="text-muted">No hay imágenes registradas</span>
                        }
                    </div>
                </div>


                <!-- Subir nuevas imágenes -->
                <div class="mb-3">
                    <label class="form-label">Subir nuevas imágenes</label>
                    <input type="file" name="ImagenesCarta" id="imagenesInput" class="form-control" multiple />
                    <small class="text-muted">Puede subir nuevas imágenes y elegir cuál será la principal</small>

                    <!-- Vista previa -->
                    <div id="preview" class="mt-3 d-flex flex-wrap gap-2"></div>
                </div>


                <!-- Estado actual -->
                <div class="mb-3">
                    <label class="form-label">Estado actual</label>
                    <input type="text" class="form-control" value="@Model.EstadoCarta?.NombreEstado" readonly />
                </div>

                <!-- Usuario vendedor -->
                <div class="mb-3">
                    <label class="form-label">Usuario vendedor</label>
                    <input type="text" class="form-control" value="@Model.Vendedor?.NombreCompleto" readonly />
                </div>

                <!-- Botones -->
                <div class="text-end">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle me-1"></i> Guardar cambios
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const input = document.getElementById('imagenesInput');
        const preview = document.getElementById('preview');

        input.addEventListener('change', () => {
            preview.innerHTML = '';
            const files = input.files;

            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                const reader = new FileReader();

                reader.onload = (e) => {
                    const wrapper = document.createElement('div');
                    wrapper.classList.add('d-flex', 'flex-column', 'align-items-center', 'me-2');

                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.maxWidth = '150px';
                    img.style.maxHeight = '150px';
                    img.style.objectFit = 'cover';
                    img.classList.add('border', 'rounded');

                    const radio = document.createElement('input');
                    radio.type = 'radio';
                    radio.name = 'ImagenPrincipalIndex';
                    radio.value = i;
                    if (i === 0) radio.checked = true;

                    const label = document.createElement('label');
                    label.textContent = "Principal";

                    wrapper.appendChild(img);
                    wrapper.appendChild(radio);
                    wrapper.appendChild(label);
                    preview.appendChild(wrapper);
                };

                reader.readAsDataURL(file);
            }
        });
    </script>
}
