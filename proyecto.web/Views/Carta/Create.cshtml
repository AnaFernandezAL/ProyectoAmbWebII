@model proyecto.Application.DTOs.CartaDTO

@{
    ViewData["Title"] = "Nueva Carta";
    var categorias = ViewBag.Categorias as IEnumerable<proyecto.Application.DTOs.CategoriaDTO>;
    var usuarioActual = ViewBag.UsuarioActual as proyecto.Application.DTOs.UsuarioDTO;
}

<div class="container my-4">
    <div class="card shadow-sm" style="max-width: 900px; margin:0 auto; border-radius:12px;">
        <div class="card-header bg-primary text-white fw-bold">
            <i class="bi bi-collection me-2"></i> Registrar nueva carta
        </div>

        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <!-- Nombre -->
                <div class="mb-3">
                    <label asp-for="NombreCarta" class="form-label"></label>
                    <input asp-for="NombreCarta" class="form-control" />
                    <span asp-validation-for="NombreCarta" class="text-danger"></span>
                </div>

                <!-- Descripción -->
                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label"></label>
                    <textarea asp-for="Descripcion" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <!-- Condición -->
                <div class="mb-3">
                    <label asp-for="Condicion" class="form-label"></label>
                    <input asp-for="Condicion" class="form-control" />
                    <span asp-validation-for="Condicion" class="text-danger"></span>
                </div>

                <!-- Edición (obligatoria) -->
                <div class="mb-3">
                    <label asp-for="Edicion" class="form-label"></label>
                    <input asp-for="Edicion" class="form-control" />
                    <span asp-validation-for="Edicion" class="text-danger"></span>
                </div>

                <!-- Rareza (obligatoria) -->
                <div class="mb-3">
                    <label asp-for="Rareza" class="form-label"></label>
                    <input asp-for="Rareza" class="form-control" />
                    <span asp-validation-for="Rareza" class="text-danger"></span>
                </div>

                <!-- Categorías -->
                <div class="mb-3">
                    <label class="form-label">Categorías</label>
                    <select asp-for="CategoriasSeleccionadas" class="form-select" multiple>
                        @if (categorias != null)
                        {
                            foreach (var categoria in categorias)
                            {
                                <option value="@categoria.CategoriaId">@categoria.NombreCategoria</option>
                            }
                        }
                    </select>
                    <span asp-validation-for="CategoriasSeleccionadas" class="text-danger"></span>
                </div>

                <!-- Imágenes -->
                <div class="mb-3">
                    <label class="form-label">Imágenes</label>
                    <input asp-for="ImagenesCarta" type="file" id="imagenesInput" class="form-control" multiple />
                    <span asp-validation-for="ImagenesCarta" class="text-danger"></span>
                    <small class="text-muted">Puede seleccionar varias imágenes a la vez o agregarlas una por una.</small>

                    <!-- Vista previa con radios para principal -->
                    <div id="preview" class="mt-3 d-flex flex-wrap gap-2"></div>
                </div>

                <!-- Estado inicial -->
                <div class="mb-3">
                    <label class="form-label">Estado inicial</label>
                    <input type="text" class="form-control" value="Activo" readonly />
                </div>

                <!-- Usuario vendedor -->
                <div class="mb-3">
                    <label class="form-label">Usuario vendedor</label>
                    <input type="text" class="form-control" value="@usuarioActual?.NombreCompleto" readonly />
                </div>

                <!-- Botones -->
                <div class="text-end">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle me-1"></i> Guardar
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        const input = document.getElementById('imagenesInput');
        const preview = document.getElementById('preview');

        input.addEventListener('change', () => {
            preview.innerHTML = '';
            const files = input.files;

            for (let i = 0; i < files.length; i++) {
                const file = files[i];
                const reader = new FileReader();

                reader.onload = (e) => {
                    const wrapper = document.createElement('div');
                    wrapper.classList.add('d-flex', 'flex-column', 'align-items-center', 'me-2');

                    const img = document.createElement('img');
                    img.src = e.target.result;
                    img.style.maxWidth = '150px';
                    img.style.maxHeight = '150px';
                    img.style.objectFit = 'cover';
                    img.classList.add('border', 'rounded');

                    const radio = document.createElement('input');
                    radio.type = 'radio';
                    radio.name = 'ImagenPrincipalIndex';
                    radio.value = i;
                    if (i === 0) radio.checked = true; // primera por defecto

                    const label = document.createElement('label');
                    label.textContent = "Principal";

                    wrapper.appendChild(img);
                    wrapper.appendChild(radio);
                    wrapper.appendChild(label);
                    preview.appendChild(wrapper);
                };

                reader.readAsDataURL(file);
            }
        });
    </script>
}