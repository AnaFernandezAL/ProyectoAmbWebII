@model proyecto.Application.DTOs.CartaDTO

@{
    ViewData["Title"] = "Eliminar Carta";
}

<div class="container my-4">
    <div class="card shadow-sm" style="max-width: 700px; margin:0 auto; border-radius:12px;">
        <div class="card-header bg-danger text-white fw-bold">
            <i class="bi bi-trash me-2"></i> Confirmar eliminación
        </div>

        <div class="card-body">
            <h5 class="mb-3">¿Está seguro que desea eliminar esta carta?</h5>

            <dl class="row">
                <dt class="col-sm-4">Nombre</dt>
                <dd class="col-sm-8">@Model.NombreCarta</dd>

                <dt class="col-sm-4">Descripción</dt>
                <dd class="col-sm-8">@Model.Descripcion</dd>

                <dt class="col-sm-4">Condición</dt>
                <dd class="col-sm-8">@Model.Condicion</dd>

                <dt class="col-sm-4">Estado actual</dt>
                <dd class="col-sm-8">@Model.EstadoCarta?.NombreEstado</dd>
            </dl>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="CartaId" />

                <div class="text-end">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash-fill me-1"></i> Eliminar
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>