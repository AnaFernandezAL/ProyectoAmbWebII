@model proyecto.Application.DTOs.SubastaDTO

@{
    ViewData["Title"] = "Editar Subasta";
}

<div class="container my-4">
    <div class="card shadow-sm" style="max-width: 900px; margin:0 auto; border-radius:12px;">
        <div class="card-header bg-info text-dark fw-bold">
            <i class="bi bi-pencil-square me-2"></i> Editar subasta
        </div>

        <div class="card-body">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="SubastaId" />

                <!-- Fecha inicio -->
                <div class="mb-3">
                    <label asp-for="FechaInicio" class="form-label"></label>
                    <input asp-for="FechaInicio" class="form-control" type="datetime-local" />
                    <span asp-validation-for="FechaInicio" class="text-danger"></span>
                </div>

                <!-- Fecha cierre -->
                <div class="mb-3">
                    <label asp-for="FechaCierre" class="form-label"></label>
                    <input asp-for="FechaCierre" class="form-control" type="datetime-local" />
                    <span asp-validation-for="FechaCierre" class="text-danger"></span>
                </div>

                <!-- Precio base -->
                <div class="mb-3">
                    <label asp-for="PrecioBase" class="form-label"></label>
                    <input asp-for="PrecioBase" class="form-control" />
                    <span asp-validation-for="PrecioBase" class="text-danger"></span>
                </div>

                <!-- Incremento mínimo -->
                <div class="mb-3">
                    <label asp-for="IncrementoMinimo" class="form-label"></label>
                    <input asp-for="IncrementoMinimo" class="form-control" />
                    <span asp-validation-for="IncrementoMinimo" class="text-danger"></span>
                </div>

                <!-- Campos no editables -->
                <div class="mb-3">
                    <label class="form-label">Carta</label>
                    <input type="text" class="form-control" value="@Model.Carta?.NombreCarta" readonly />
                </div>

                <div class="mb-3">
                    <label class="form-label">Estado actual</label>
                    <input type="text" class="form-control" value="@Model.EstadoSubasta?.NombreEstado" readonly />
                </div>

                <!-- Botones -->
                <div class="text-end">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle me-1"></i> Guardar cambios
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left-circle me-1"></i> Cancelar
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
