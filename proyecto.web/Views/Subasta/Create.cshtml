@using proyecto.web.ViewModels
@model SubastaCreateViewModel

@{
    ViewData["Title"] = "Nueva Subasta";
}

<style>
    ul.ui-autocomplete {
        z-index: 1100;
    }
</style>

<div class="container">
    <h2 class="mb-3">Nueva Subasta</h2>

    <form id="createSubastaForm" asp-action="Create" method="post">
        @Html.AntiForgeryToken()

        <div class="card shadow-sm">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">Datos de la Subasta</span>
                <button type="button"
                        class="btn btn-outline-secondary btn-sm"
                        onclick="clearForm()">
                    Nueva Subasta
                </button>
            </div>

            <div class="card-body">
                <div class="row">

                    <!-- IZQUIERDA: DATOS -->
                    <div class="col-md-4 border-end">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

                        <div class="mb-3">
                            <label asp-for="Subasta.FechaInicio"></label>
                            <input asp-for="Subasta.FechaInicio"
                                   type="datetime-local"
                                   class="form-control form-control-sm"
                                   value="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")"
                                   min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Subasta.FechaCierre"></label>
                            <input asp-for="Subasta.FechaCierre"
                                   type="datetime-local"
                                   class="form-control form-control-sm"
                                   value="@DateTime.Now.AddDays(7).ToString("yyyy-MM-ddTHH:mm")"
                                   min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                        </div>


                        <div class="mb-3">
                            <label asp-for="Subasta.PrecioBase"></label>
                            <input asp-for="Subasta.PrecioBase" class="form-control form-control-sm" />
                        </div>

                        <div class="mb-3">
                            <label asp-for="Subasta.IncrementoMinimo"></label>
                            <input asp-for="Subasta.IncrementoMinimo" class="form-control form-control-sm" />
                        </div>

                        <!-- BOTÓN -->
                        <div class="d-grid gap-2">
                            <button type="button"
                                    class="btn btn-success btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalCartas">
                                Buscar carta
                            </button>
                        </div>

                    </div>

                    <!-- DERECHA: CARTA SELECCIONADA -->
                    <div class="col-md-8">

                        <div class="card h-100">
                            <div class="card-header">
                                Carta seleccionada
                            </div>

                            <div class="card-body text-center">

                                <!-- ID OCULTO -->
                                <input type="hidden" asp-for="Subasta.CartaId" id="CartaId" />

                                <!-- IMAGEN -->
                                <img src="/Images/nophoto.jpg"
                                     id="CartaImagen"
                                     class="img-fluid rounded border mb-3"
                                     style="max-height: 250px;" />

                                <!-- NOMBRE -->
                                <h5 id="CartaNombre">Ninguna carta seleccionada</h5>

                                <!-- DESCRIPCIÓN -->
                                <p id="CartaDescripcion" class="text-muted">
                                    Seleccione una carta para ver su información
                                </p>

                            </div>
                        </div>

                    </div>

                </div>
            </div>

            <div class="card-footer text-end">
                <button type="submit" class="btn btn-primary">
                    Crear Subasta
                </button>
                <a asp-action="Index" class="btn btn-secondary">
                    Regresar
                </a>
            </div>
        </div>
    </form>
</div>

<!-- MODAL -->
<div class="modal fade" id="modalCartas" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Seleccionar carta</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                @await Html.PartialAsync("_AddCarta", new ViewModelInput())
            </div>

        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")

    <script>

        function getToken() {
            return document.querySelector('#createSubastaForm input[name="__RequestVerificationToken"]').value;
        }

        function clearForm() {
            const form = document.getElementById("createSubastaForm");
            form.reset();

            $("#CartaId").val("");
            $("#CartaNombre").html("Ninguna carta seleccionada");
            $("#CartaDescripcion").html("Seleccione una carta para ver su información");
            $("#CartaImagen").attr("src", "/Images/nophoto.jpg");

            Swal.fire({
                icon: 'info',
                title: 'Formulario reiniciado'
            });
        }

                // ============================================================
        //  GUARDAR Subasta (fetch POST + SweetAlert)
        // ============================================================
        document.getElementById("createSubastaForm").addEventListener("submit", async function (e) {
            e.preventDefault();

            const form = this;
            const token = getToken();
            const formData = new FormData(form);

            if (!$("#CartaId").val()) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error',
                    text: 'Debe seleccionar una carta'
                });
                return;
            }

            try {
                const response = await fetch(form.action, {
                    method: "POST",
                    headers: { "RequestVerificationToken": token },
                    body: formData
                });

                if (!response.ok) {
                    const errorText = await response.text();

                    Swal.fire({
                        icon: 'error',
                        title: 'Error al guardar',
                        text: errorText
                    });
                    return;
                }

                const result = await response.json();

                if (result.success && result.redirectUrl) {
                    Swal.fire({
                        icon: 'success',
                        title: 'Subasta creada',
                        text: 'La Subasta se creó correctamente.',
                        timer: 1200,
                        showConfirmButton: false
                    }).then(() => {
                        window.location.href = result.redirectUrl;
                    });
                }
                else {
                    Swal.fire({
                        icon: 'warning',
                        title: 'Guardado parcial',
                        text: 'La Subasta se creó pero no se obtuvo redirección.'
                    });
                }

            } catch (error) {
                Swal.fire({
                    icon: 'error',
                    title: 'Error inesperado',
                    text: error.message
                });
            }
        });

        // ============================================================
        //  AGREGAR Carta AL Subasta
        // ============================================================
        function seleccionarCarta(id, nombre, descripcion, imagen) {

            $("#CartaId").val(id);
            $("#CartaNombre").html(nombre);
            $("#CartaDescripcion").html(descripcion ?? "Sin descripción");

            if (imagen) {
                $("#CartaImagen").attr("src", imagen);
            } else {
                $("#CartaImagen").attr("src", "/Images/nophoto.jpg");
            }

            $("#modalCartas").modal('hide');
        }

        function confirmarCarta() {

            const input = $("#CartaIdSeleccionada");
            const id = input.val();

            if (!id) {
                Swal.fire("Error", "Debe seleccionar una carta", "error");
                return;
            }

            const nombre = input.data("nombre");
            const descripcion = input.data("descripcion");
            const imagen = input.data("imagen");

            seleccionarCarta(id, nombre, descripcion, imagen);

            const modal = bootstrap.Modal.getInstance(document.getElementById('modalCartas'));
            modal.hide();

            Swal.fire({
                icon: "success",
                title: "Carta agregada",
                timer: 800,
                showConfirmButton: false
            });
        }


        // ============================================================
        //  AUTOCOMPLETE Carta
        // ============================================================
                $(document).ready(function () {

            function activarAutocomplete() {

                const input = $("#NombreCartaModal");


                console.log("ACTIVANDO AUTOCOMPLETE");

                input.autocomplete({
                    minLength: 1,

                    source: function (request, response) {


                        $.ajax({
                            url: '@Url.Action("GetCartaByName", "Carta")',
                            data: { filtro: request.term },

                            success: function (data) {

                                console.log("DATA:", data);

                                response($.map(data, function (item) {
                                    return {
                                        label: item.nombre,
                                        value: item.nombre,
                                        data: item
                                    };
                                }));
                            }
                        });
                    },

                    select: function (event, ui) {

                        const carta = ui.item.data;

                        $("#CartaIdSeleccionada").val(carta.cartaId);

                        // 🔥 GUARDAR IMAGEN REAL
                        $("#CartaIdSeleccionada").data("imagen", carta.imagen);
                        $("#CartaIdSeleccionada").data("nombre", carta.nombre);
                        $("#CartaIdSeleccionada").data("descripcion", carta.descripcion);

                        $("#CartaSelect").html("Carta: " + carta.nombre);
                        $("#DescripcionSelect").html("Descripción: " + (carta.descripcion ?? "Sin descripción"));
                        $("#EstadoCartaSelect").html("Estado: " + (carta.estado ?? "Disponible"));

                        if (carta.imagen) {
                            $("#ImgCarta").attr("src", carta.imagen);
                        }

                        return false;
                    }
                });
            }
            activarAutocomplete();

            $(document).on("shown.bs.modal", "#modalCartas", function () {
                activarAutocomplete();
            });

        });


    </script>
}