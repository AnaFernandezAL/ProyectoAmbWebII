@model X.PagedList.IPagedList<proyecto.Application.DTOs.SubastaDTO>
@using X.PagedList.Mvc.Core

@{
    ViewData["Title"] = "Subastas Activas";
}

<div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-2 mb-3">
    <div>
        <h1 class="h3 mb-1">Subastas Activas</h1>
        <p class="text-muted mb-0">Listado de subastas actualmente abiertas.</p>
    </div>

    <div class="d-flex align-items-center gap-2">
        <span class="badge text-bg-secondary" title="Total de subastas activas">@Model?.TotalItemCount</span>
    </div>
</div>

<div class="card shadow-sm">
    <ul class="nav nav-tabs card-header-tabs px-3">
        <li class="nav-item">
            <a class="nav-link @(ViewData["Title"]?.ToString() == "Subastas" ? "active" : "")" asp-action="Index">
                <i class="bi bi-list-ul me-1"></i> Todas
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewData["Title"]?.ToString() == "Subastas Activas" ? "active" : "")" asp-action="Activas">
                <i class="bi bi-play-circle me-1"></i> Activas
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(ViewData["Title"]?.ToString() == "Subastas Finalizadas" ? "active" : "")" asp-action="Finalizadas">
                <i class="bi bi-stop-circle me-1"></i> Finalizadas
            </a>
        </li>
    </ul>

    <div class="card-body p-0">
        @if (Model == null || !Model.Any())
        {
            <div class="p-4 text-center">
                <div class="display-6 mb-2">
                    <i class="bi bi-box-seam"></i>
                </div>
                <h2 class="h5">No hay subastas activas</h2>
                <p class="text-muted mb-3">Cuando se cree una nueva subasta, aparecerá aquí.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light position-sticky top-0" style="z-index:1;">
                        <tr>
                            <th scope="col" class="ps-3">Objeto</th>
                            <th scope="col">Imagen</th>
                            <th scope="col">Fecha Inicio</th>
                            <th scope="col">Fecha Cierre</th>
                            <th scope="col">Cantidad de Pujas</th>
                            <th scope="col" class="text-end pe-3" style="width: 180px;">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var subasta in Model)
                        {
                            <tr>
                                <td class="ps-3">
                                    <div class="fw-semibold">@subasta.Carta?.NombreCarta</div>
                                </td>
                                <td>
                                    @if (subasta.Carta?.ImagenesCarta != null && subasta.Carta.ImagenesCarta.Any())
                                    {
                                        <img src="@subasta.Carta.ImagenesCarta.First().UrlImagen"
                                             alt="@subasta.Carta.NombreCarta"
                                             class="img-thumbnail"
                                             style="max-height:80px;" />
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin imagen</span>
                                    }
                                </td>
                                <td>@subasta.FechaInicio.ToString("dd/MM/yyyy")</td>
                                <td>@subasta.FechaCierre.ToString("dd/MM/yyyy")</td>
                                <td>
                                    <span class="badge bg-info text-dark">@subasta.CantidadPujas</span>
                                </td>
                                <td class="text-end pe-3">
                                    <a asp-action="Details" asp-route-id="@subasta.SubastaId"
                                       class="btn btn-outline-secondary btn-sm"
                                       title="Ver detalle">
                                        <i class="bi bi-eye"></i>
                                        <span class="d-none d-lg-inline ms-1">Detalle</span>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="card-footer bg-body d-flex flex-column flex-md-row align-items-center justify-content-between gap-2 small text-muted">
        <div>
            Total: <strong>@Model?.TotalItemCount</strong> subasta(s) activa(s)
        </div>

        @if (Model != null && Model.PageCount > 1)
        {
            <nav aria-label="Paginación de subastas activas">
                @Html.PagedListPager(
                Model,
                        page => Url.Action("Activas", new { page }),
                        new PagedListRenderOptions
                        {
                            UlElementClasses = new[] { "pagination", "mb-0" },
                            LiElementClasses = new[] { "page-item" },
                            PageClasses = new[] { "page-link" },
                            DisplayLinkToFirstPage = PagedListDisplayMode.Always,
                            DisplayLinkToLastPage = PagedListDisplayMode.Always,
                            DisplayLinkToPreviousPage = PagedListDisplayMode.Always,
                            DisplayLinkToNextPage = PagedListDisplayMode.Always,
                            MaximumPageNumbersToDisplay = 5
                        }
                        )
        </nav>
                }
    </div>
</div>